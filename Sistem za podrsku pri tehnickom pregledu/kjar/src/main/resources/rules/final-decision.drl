rule "FINAL: Vehicle passed — no failures detected"
    salience 5         // lowest — only fires if nothing else has resolved the decision
    when
        $d : FinalDecision(resolved == false)
        not InspectionIssue(passed == false)
    then

        modify($d){
                setResult(InspectionResult.PROSAO),
                setPrimaryReason("Vozilo ispunjava sve tehničke uslove."),
                setResolved(true)
        };
end
