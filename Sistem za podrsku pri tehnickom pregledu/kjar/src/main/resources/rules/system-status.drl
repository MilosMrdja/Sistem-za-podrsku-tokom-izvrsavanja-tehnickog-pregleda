// ===============================================================================
//  ADDITIONAL FAILURES ACCUMULATION (Salience 49)
//  Continues to collect distinct descriptions after the system is already failed.
// ===============================================================================

rule "STATUS: Accumulate additional brake failures"
    salience 49
    when
        $issue  : InspectionIssue(system == "BRAKE_SYSTEM", passed == false)
        $status : SystemStatus(systemName == SystemStatus.BRAKE_SYSTEM, failed == true,
                               !failureReasons.contains($issue.getDescription()))
    then
        List<String> reasons = new ArrayList<>($status.getFailureReasons());
        reasons.add($issue.getDescription());
        modify($status){
            setFailureReasons(reasons)
        };
end

