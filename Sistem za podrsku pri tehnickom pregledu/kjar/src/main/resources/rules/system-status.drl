package rules;

import sistem_tehnicki_pregled.model.models.InspectionIssue;
import sistem_tehnicki_pregled.model.models.SystemStatus;
import java.util.List;
import java.util.ArrayList;

// ═══════════════════════════════════════════════════════════════════════════════
//  LEVEL 2 — SYSTEM STATUS AGGREGATION
//  Salience 50 & 49 — fires after all Level-1 detection rules.
//
//  One SystemStatus instance per logical system is pre-inserted by the service.
//  These rules set their `failed` flag and accumulate failure reasons.
// ═══════════════════════════════════════════════════════════════════════════════

// ===============================================================================
//  FIRST FAILURE INITIALIZATION (Salience 50)
//  Fires when the first issue is detected for a system where failed == false.
// ===============================================================================

rule "STATUS: Aggregate brake system issues"
    salience 50
    when
        $issue  : InspectionIssue(system == "BRAKE_SYSTEM", passed == false)
        $status : SystemStatus(systemName == SystemStatus.BRAKE_SYSTEM, failed == false)
    then
        List<String> reasons = new ArrayList<>($status.getFailureReasons());
        reasons.add($issue.getDescription());
        modify($status){
            setFailureReasons(reasons),
            setFailed(true)
        };
end

