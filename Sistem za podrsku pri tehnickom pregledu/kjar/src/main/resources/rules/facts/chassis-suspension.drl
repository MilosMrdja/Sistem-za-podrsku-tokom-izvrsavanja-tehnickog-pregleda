package rules;

import sistem_tehnicki_pregled.model.facts.SuspensionSystemFact;
import sistem_tehnicki_pregled.model.models.InspectionIssue;

rule "SUSPENSION: Control arms (poluge) damaged"
    salience 90
    when
        $s : SuspensionSystemFact(armsIntact == false)
    then
        insert(InspectionIssue.of(
            "CHASSIS_SUSPENSION", "SUSPENSION_ARMS", "MECHANICAL_DAMAGE",
            "Mehaničko oštećenje na polugama oslanjanja."
        ));
end

