package rules;

import sistem_tehnicki_pregled.model.facts.MandatoryEquipmentFact;
import sistem_tehnicki_pregled.model.models.InspectionIssue;

rule "EQUIPMENT: Spare wheel missing"
    salience 90
    when
        $eq : MandatoryEquipmentFact(spareWheelPresent == false)
    then
        insert(InspectionIssue.of(
            "MANDATORY_EQUIPMENT", "EQUIPMENT", "SPARE_WHEEL_MISSING",
            "Nedostaje rezervni točak."
        ));
end

